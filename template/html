<!DOCTYPE html>
<html>
<head>
<title>Sigen C&I Solar Calculator</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>
body{
font-family:Arial;
background:#f2f2f2;
padding:20px;
}
.box{
max-width:500px;
margin:auto;
background:white;
padding:20px;
border-radius:12px;
}
input,select,button{
width:100%;
padding:10px;
margin:8px 0;
}
button{
background:#198754;
color:white;
border:0;
font-size:16px;
}
.result{
background:#eef5ff;
padding:15px;
margin-top:15px;
border-radius:8px;
}
.diagram{
font-family:monospace;
background:#222;
color:white;
padding:15px;
margin-top:15px;
}
</style>
</head>

<body>

<div class="box">

<h2>Sigen C&I Solar Calculator</h2>

<label>PV Capacity (kWp)</label>
<input id="pv" value="110">

<label>Inverter Capacity (kW)</label>
<input id="inv" value="30">

<label>Panel Watt</label>
<select id="panel">
<option value="550">550W</option>
<option value="600" selected>600W</option>
<option value="700">700W</option>
</select>

<label>System Type</label>
<select id="type">
<option>On Grid</option>
<option>Hybrid</option>
</select>

<button onclick="calc()">Calculate</button>


<div class="result" id="result"></div>

<div class="diagram" id="diagram"></div>


</div>


<script>

function calc(){

let pv=Number(document.getElementById("pv").value);
let inv=Number(document.getElementById("inv").value);
let watt=Number(document.getElementById("panel").value);
let type=document.getElementById("type").value;


let qty=Math.ceil((pv*1000)/watt);
let ratio=(pv/inv).toFixed(2);


document.getElementById("result").innerHTML=
`
<b>System Summary</b><br><br>
PV Size : ${pv} kWp<br>
Inverter : ${inv} kW<br>
Panel Qty : ${qty} pcs<br>
DC/AC Ratio : ${ratio}<br>
System : ${type}
`;


if(type=="On Grid"){
document.getElementById("diagram").innerHTML=
`
PV ARRAY<br>
&nbsp;&nbsp;│<br>
DC ISOLATOR<br>
&nbsp;&nbsp;│<br>
SIGEN ${inv}kW INV<br>
&nbsp;&nbsp;│<br>
AC MCCB<br>
&nbsp;&nbsp;│<br>
MAIN DB<br>
&nbsp;&nbsp;│<br>
GRID
`;
}
else{
document.getElementById("diagram").innerHTML=
`
PV ARRAY<br>
&nbsp;&nbsp;│<br>
SIGEN HYBRID INV<br>
&nbsp;&nbsp;│<br>
BATTERY<br>
&nbsp;&nbsp;│<br>
LOAD DB<br>
&nbsp;&nbsp;│<br>
GRID
`;
}

}

</script>

</body>
</html>
